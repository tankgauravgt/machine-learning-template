#!/bin/bash

# 1. cuDNN headers and libraries (for transformer-engine)
export C_INCLUDE_PATH=${C_INCLUDE_PATH:-}:$(pwd)/.venv/lib/python3.14/site-packages/nvidia/cudnn/include
export CPLUS_INCLUDE_PATH=${CPLUS_INCLUDE_PATH:-}:$(pwd)/.venv/lib/python3.14/site-packages/nvidia/cudnn/include
export LD_LIBRARY_PATH=${LD_LIBRARY_PATH:-}:$(pwd)/.venv/lib/python3.14/site-packages/nvidia/cudnn/lib

# 2. CUDA toolkit and architecture (for flash-attn compilation)
export CUDA_HOME=$(pwd)/.venv/lib/python3.14/site-packages/nvidia/cu13
